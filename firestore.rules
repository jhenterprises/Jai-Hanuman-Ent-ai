rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly bootstrap the admin emails so they cannot be locked out.
    function isBootstrapAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shahisthabanu78@gmail.com' || 
        request.auth.token.email == 'pancardjhc2018@gmail.com' ||
        request.auth.token.email == 'admin@jhportal.gov.in'
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role in ['staff', 'admin']
      );
    }

    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == 'admin'
      );
    }

    // --- Default Catch-All ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users ---
    match /users/{userId} {
      allow read, get: if isSignedIn();
      allow list: if isStaff();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Support Chats & Messages (supportChats & supportMessages) ---
    match /supportChats/{chatId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }

    match /supportMessages/{messageId} {
      allow read: if isSignedIn() && (
        resource == null || 
        resource.data.senderId == request.auth.uid || 
        isStaff()
      );
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid || 
        isStaff()
      );
      allow update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isStaff()
      );
      allow delete: if isAdmin();
    }

    // --- Chats / Messages Support System (Legacy Chats Path) ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && (chatId == request.auth.uid || isStaff());
      allow create, update: if isSignedIn() && (chatId == request.auth.uid || isStaff());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (chatId == request.auth.uid || isStaff());
        allow create, update: if isSignedIn() && (chatId == request.auth.uid || isStaff());
        allow delete: if isAdmin();
      }
    }

    match /quickReplies/{replyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Ledger System ---
    match /ledger/{docId} {
      // Staff can read all. Users can read their own entries.
      allow read: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      // Staff can create. Users can create if they attribute it to themselves.
      allow create: if isStaff() || (isSignedIn() && request.resource.data.user_id == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Core Wallets ---
    match /wallets/{docId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      // Users can manage their wallet entries.
      allow create, update: if isStaff() || (isSignedIn() && request.resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    // --- Document System ---
    match /documentFolders/{docId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.ownerId == request.auth.uid || resource.data.ownerId == 'global');
      allow create: if isSignedIn() && (isStaff() || request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isSignedIn() && (isStaff() || resource.data.ownerId == request.auth.uid);
    }

    match /documents/{docId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.ownerId == request.auth.uid || resource.data.ownerId == 'global');
      allow create: if isSignedIn() && (isStaff() || request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isSignedIn() && (isStaff() || resource.data.ownerId == request.auth.uid);
    }

    // --- Notifications ---
    match /notifications/{docId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isStaff();
      allow update: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }

    // --- Standard Fallback matching one-level Collections ---
    match /{collectionName}/{docId} {
      allow read: if isSignedIn();
      allow write: if isStaff() || (isSignedIn() && (
        request.resource.data.user_id == request.auth.uid || 
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.customerId == request.auth.uid
      ));
    }
  }
}
