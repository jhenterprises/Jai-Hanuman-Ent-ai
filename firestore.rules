rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '') != '' &&
             request.auth.token.email.toLowerCase() in [
               "pancardjhc2018@gmail.com",
               "pavan.tr16@gmail.com",
               "admin@jh.com"
             ];
    }

    function isVerified() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        request.auth.token.get('email_verified', false) == true
      );
    }
    
    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      );
    }

    function isStaff() {
      return isBootstrapAdmin() || isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'staff'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isStaff());
      allow list: if isStaff() || isBootstrapAdmin();
      
      allow create: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isAdmin());
      allow delete: if isBootstrapAdmin() || isAdmin();
    }

    // Pillar 0: Global Safety Net
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    // -------------------------------------------------------------------------
    // SERVICES & SERVICE LINKS
    // -------------------------------------------------------------------------
    
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_inputs/{inputId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // APPLICATIONS COLLECTION
    // -------------------------------------------------------------------------
    
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.userId == request.auth.uid &&
               data.reference_number is string && data.reference_number.size() <= 50;
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());

      allow create: if isVerified() && isValidApplication(incoming());
      
      allow update: if isStaff() || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['form_data', 'documents', 'updated_at']) &&
        (existing().status == 'Pending' || existing().status == 'Submitted' || existing().status == 'Documents Required')
      );
      
      allow delete: if isStaff();
    }

    match /application_drafts/{draftId} {
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // LEDGER & WALLETS
    // -------------------------------------------------------------------------
    
    match /ledger/{ledgerId} {
      function isValidLedgerEntry(data) {
        return data.customer_name is string && data.customer_name.size() > 0 &&
               data.principle_amount is number &&
               data.created_at is timestamp;
      }
      allow get: if isSignedIn() && (resource.data.staff_id == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.staff_id == request.auth.uid || isStaff());
      allow create: if isVerified() && isValidLedgerEntry(incoming());
      allow update: if isStaff() && 
                    incoming().staff_id == existing().staff_id &&
                    incoming().created_at == existing().created_at;
      allow delete: if isAdmin() || (isStaff() && resource.data.staff_id == request.auth.uid);
    }

    match /withdrawals/{withdrawalId} {
       allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
       allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
       allow create: if isSignedIn();
       allow update, delete: if isAdmin();
    }

    match /counters/{counterId} {
        allow read: if isStaff();
        allow write: if isStaff() || isSignedIn();
    }

    match /wallets/{walletId} {
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isStaff());
      allow create: if isVerified();
      allow update: if (isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid)) || isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SUPPORT & ACTIVITY
    // -------------------------------------------------------------------------

    match /support_tickets/{ticketId} {
      allow list: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff() || (isSignedIn() && existing().user_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow list, get: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /recycle_bin/{binId} {
      allow list, get: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ATTENDANCE COLLECTION
    // -------------------------------------------------------------------------
    match /attendance/{recordId} {
      function isValidAttendance(data) {
        return data.keys().hasAll(['userId', 'staff_name', 'staff_id', 'date', 'status', 'updated_at']) &&
               data.keys().size() >= 6 && data.keys().size() <= 7 &&
               isValidId(data.userId) &&
               data.staff_name is string && data.staff_name.size() <= 200 &&
               data.staff_id is string &&
               data.date is string && data.date.size() <= 20 &&
               data.status in ['Full Day', 'Half Day', 'Absent'] &&
               data.updated_at is timestamp &&
               (data.keys().size() == 6 || (data.keys().hasAll(['isAuto']) && data.isAuto is bool));
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidAttendance(incoming());
      allow update: if isSignedIn() && (isValidAttendance(incoming()) && (
        isStaff() || 
        (existing().userId == request.auth.uid && incoming().userId == existing().userId)
      ));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SALARIES COLLECTION
    // -------------------------------------------------------------------------
    match /salaries/{salaryId} {
      function isValidSalary(data) {
        return data.keys().hasAll(['userId', 'staff_name', 'staff_id', 'month', 'base_salary', 'total_days', 'present_days', 'payable_salary', 'status', 'updated_at']) &&
               data.keys().size() == 10 &&
               isValidId(data.userId) &&
               data.staff_name is string && data.staff_name.size() <= 200 &&
               data.staff_id is string &&
               data.month is string && data.month.size() <= 50 &&
               data.base_salary is number &&
               data.total_days is number &&
               data.present_days is number &&
               data.payable_salary is number &&
               data.status in ['Pending', 'Paid'] &&
               data.updated_at is timestamp;
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      allow create: if isAdmin() && isValidSalary(incoming());
      allow update: if isAdmin() && (isValidSalary(incoming()) || (
        isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paid_at', 'updated_at'])
      ));
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list, get: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow create: if isStaff();
      allow update: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // SETTINGS / CONFIG
    // -------------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
