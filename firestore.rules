rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --------------------------------------------------
    // GLOBAL HELPERS
    // --------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn(); // Relaxed for now, but in production should be request.auth.token.email_verified == true;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isStaff() {
      return isSignedIn() && getUserData().role == 'staff';
    }
    
    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny for non-matched documents
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --------------------------------------------------
    // USERS COLLECTION
    // --------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // --------------------------------------------------
    // SERVICES COLLECTION
    // --------------------------------------------------
    match /services/{serviceId} {
      allow read: if true; // Public services list
      allow write: if isAdmin();
    }
    
    match /service_inputs/{inputId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /service_document_requirements/{reqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------------------------
    // APPLICATIONS COLLECTION
    // --------------------------------------------------
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow create: if isSignedIn();
      allow update: if isAdminOrStaff() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'Pending');
      allow delete: if isAdmin();
    }

    // --------------------------------------------------
    // WALLETS & LEDGER
    // --------------------------------------------------
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdminOrStaff();
      allow write: if isAdmin(); // Only admin can Top-up or adjust balance directly via API/Admin panel
    }
    
    match /ledger/{entryId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow write: if isAdmin();
    }

    // --------------------------------------------------
    // SETTINGS / CONFIG
    // --------------------------------------------------
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdminOrStaff();
      allow create: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow write: if isAdminOrStaff();
    }

    match /service_payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdminOrStaff());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // --------------------------------------------------
    // TEST
    // --------------------------------------------------
    match /test/{document=**} {
      allow read, write: if true;
    }
  }
}
