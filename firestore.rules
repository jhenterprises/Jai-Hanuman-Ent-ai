rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Pillar 0: Global Safety Net - MUST BE FIRST OR INDEPENDENT
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    function isBootstrapAdmin() {
      return isSignedIn() && (
             request.auth.token.get('email', '').toLowerCase() == "pancardjhc2018@gmail.com" ||
             request.auth.token.get('email', '').toLowerCase() == "pavan.tr16@gmail.com" ||
             request.auth.token.get('email', '').toLowerCase() == "admin@jh.com" ||
             request.auth.uid == "L3ksRUWbvhe7EiB2iuAyraPVUua2"
      );
    }

    function isVerified() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        request.auth.token.get('email_verified', false) == true
      );
    }
    
    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      );
    }

    function isStaff() {
      return isBootstrapAdmin() || isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'staff'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      // Simplified regex to avoid matching issues, allows standard IDs
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isStaff());
      allow list: if isStaff() || isBootstrapAdmin();
      
      allow create: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin() || isAdmin());
      allow delete: if isBootstrapAdmin() || isAdmin();
    }

    // -------------------------------------------------------------------------
    // SERVICES & SERVICE LINKS
    // -------------------------------------------------------------------------
    
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_inputs/{inputId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // APPLICATIONS COLLECTION
    // -------------------------------------------------------------------------
    
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.userId == request.auth.uid &&
               data.reference_number is string && data.reference_number.size() <= 50;
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());

      allow create: if isVerified() && isValidApplication(incoming());
      
      allow update: if isStaff() || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['form_data', 'documents', 'updated_at']) &&
        (existing().status == 'Pending' || existing().status == 'Submitted' || existing().status == 'Documents Required')
      );
      
      allow delete: if isStaff();
    }

    match /application_drafts/{draftId} {
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // LEDGER & WALLETS
    // -------------------------------------------------------------------------

    match /ledger_config/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /ledger/{ledgerId} {
      function isValidLedgerEntryData(data) {
        return data.userId is string &&
               data.createdAt is timestamp &&
               data.data is map;
      }
      
      // Keep existing rules for backward compatibility if needed, but prioritize the new structure
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.staff_id == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.staff_id == request.auth.uid || isStaff());
      allow create: if isSignedIn() && (
        (incoming().keys().hasAll(['userId', 'createdAt', 'data']) && incoming().userId == request.auth.uid) ||
        (incoming().keys().hasAll(['staff_id', 'created_at']) && incoming().staff_id == request.auth.uid)
      );
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
       allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
       allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isStaff());
       allow create: if isSignedIn();
       allow update, delete: if isAdmin();
    }

    match /counters/{counterId} {
        allow read: if isStaff();
        allow write: if isStaff() || isSignedIn();
    }

    match /wallets/{walletId} {
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isStaff());
      allow create: if isVerified();
      allow update: if (isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid)) || isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SUPPORT & ACTIVITY
    // -------------------------------------------------------------------------

    match /support_tickets/{ticketId} {
      allow list: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff() || (isSignedIn() && existing().user_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow list, get: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /recycle_bin/{binId} {
      allow list, get: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ATTENDANCE COLLECTION
    // -------------------------------------------------------------------------
    match /attendance/{recordId} {
      function isValidAttendance(data) {
        return data.keys().hasAll(['userId', 'staff_name', 'staff_id', 'date', 'status', 'updated_at']) &&
               isValidId(data.userId) &&
               data.staff_name is string && data.staff_name.size() <= 200 &&
               data.staff_id is string &&
               data.date is string && data.date.size() <= 20 &&
               data.status in ['Full Day', 'Half Day', 'Absent'] &&
               data.updated_at is timestamp &&
               (data.keys().size() == 6 || (data.keys().hasAll(['isAuto']) && data.isAuto is bool));
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      allow create: if isStaff() && isValidId(recordId) && isValidAttendance(incoming());
      allow update: if isStaff() && isValidId(recordId) && (isValidAttendance(incoming()) || (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updated_at'])
      ));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SALARIES COLLECTION
    // -------------------------------------------------------------------------
    match /salaries/{salaryId} {
      function isValidSalary(data) {
        return data.keys().hasAll(['userId', 'staff_name', 'staff_id', 'month', 'base_salary', 'total_days', 'present_days', 'payable_salary', 'status', 'updated_at']) &&
               isValidId(data.userId) &&
               data.staff_name is string && data.staff_name.size() <= 200 &&
               data.staff_id is string &&
               data.month is string && data.month.size() <= 50 &&
               data.base_salary is number &&
               data.total_days is number &&
               data.present_days is number &&
               data.payable_salary is number &&
               data.status in ['Pending', 'Paid'] &&
               data.updated_at is timestamp &&
               (data.keys().size() == 10 || (data.keys().hasAll(['paid_at']) && data.paid_at is timestamp));
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      allow create: if isStaff() && isValidId(salaryId) && isValidSalary(incoming());
      allow update: if isStaff() && isValidId(salaryId) && (isValidSalary(incoming()) || (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paid_at', 'updated_at'])
      ));
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list, get: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow create: if isStaff();
      allow update: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // SETTINGS / CONFIG
    // -------------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CHATS & MESSAGES
    // -------------------------------------------------------------------------

    match /chats/{chatId} {
      function isValidChat(data) {
        return data.keys().hasAll(['customerId', 'customerName', 'status', 'createdAt']) &&
               data.customerId is string &&
               data.customerName is string &&
               data.status in ['open', 'closed'] &&
               data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid && isValidChat(incoming());
      allow update: if isStaff() || (isSignedIn() && existing().customerId == request.auth.uid && incoming().customerId == existing().customerId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.keys().hasAll(['chatId', 'senderId', 'senderName', 'text', 'timestamp']) &&
                 data.chatId == chatId &&
                 data.senderId == request.auth.uid &&
                 data.text is string && data.text.size() > 0 &&
                 data.timestamp is timestamp;
        }

        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid || isStaff());
        allow create: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid || isStaff()) && isValidMessage(incoming());
      }
    }
  }
}
