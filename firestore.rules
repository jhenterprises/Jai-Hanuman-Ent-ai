rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function getEmail() {
      return (request.auth != null && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email != null) ? request.auth.token.email.toLowerCase() : '';
    }

    function isBootstrapAdmin() {
      return isSignedIn() && (
        getEmail() == "pancardjhc2018@gmail.com" || 
        getEmail() == "pavan.tr16@gmail.com" || 
        getEmail() == "admin@jh.com"
      );
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserDoc() != null &&
             getUserDoc().data.get('role', '') == role;
    }

    function isAdmin() {
      return isBootstrapAdmin() || hasRole('admin');
    }

    function isStaff() {
      return isAdmin() || hasRole('staff');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 0: Global Safety Net & Bootstrap Admin Bypass
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isStaff());
      
      allow create: if isSignedIn() && (request.auth.uid == userId || isBootstrapAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SERVICES & SERVICE LINKS
    // -------------------------------------------------------------------------
    
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_inputs/{inputId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // APPLICATIONS COLLECTION (Pillar 1 & 8)
    // -------------------------------------------------------------------------
    
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.userId == request.auth.uid &&
               data.reference_number is string && data.reference_number.size() <= 50;
      }

      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() && isValidApplication(incoming());
      
      allow update: if isStaff() || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['form_data', 'documents', 'updated_at']) &&
        (existing().status == 'Pending' || existing().status == 'Submitted')
      );
      
      allow delete: if isAdmin();
    }

    match /application_drafts/{draftId} {
      allow list, get: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // LEDGER & WALLETS (Pillar 7: Atomicity)
    // -------------------------------------------------------------------------
    
    match /ledger/{ledgerId} {
      function isValidLedgerEntry(data) {
        return data.customer_name is string && data.customer_name.size() > 0 &&
               data.principle_amount is number &&
               data.created_at is timestamp;
      }
      allow list, get: if isStaff();
      allow create: if isStaff() && isValidLedgerEntry(incoming());
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
       allow list, get: if isStaff();
       allow create: if isStaff();
       allow update, delete: if isAdmin();
    }

    match /counters/{counterId} {
        allow read: if isStaff();
        allow write: if isStaff();
    }

    match /wallets/{walletId} {
      allow get: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow list: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create, update: if isSignedIn(); 
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SUPPORT & ACTIVITY
    // -------------------------------------------------------------------------

    match /support_tickets/{ticketId} {
      allow list: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff() || (isSignedIn() && existing().user_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow list, get: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /recycle_bin/{binId} {
      allow list, get: if isStaff();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list, get: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow create: if isStaff();
      allow update: if isSignedIn() && (isStaff() || resource.data.user_id == request.auth.uid);
      allow delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // SETTINGS / CONFIG
    // -------------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
