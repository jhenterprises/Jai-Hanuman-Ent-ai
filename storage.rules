rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all users (publicly viewable files if needed)
      // Or restrict to authenticated users
      allow read: if true;
      
      // Allow write access only to authenticated users
      // You can further restrict this to specific folders per user
      allow write: if request.auth != null;
    }
    
    // Example of user-specific folder restriction
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Example of application-specific folder restriction
    match /applications/{appId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
