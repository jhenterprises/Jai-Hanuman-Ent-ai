{
  "entities": {
    "LedgerFieldConfig": {
      "title": "Ledger Field Configuration",
      "description": "Configuration for dynamic ledger input fields",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Unique key for the field (camelCase, no spaces)"
        },
        "label": {
          "type": "string",
          "description": "Display label for the field"
        },
        "type": {
          "type": "string",
          "enum": ["text", "number", "select", "date"],
          "description": "Input type"
        },
        "options": {
          "type": "array",
          "description": "Dropdown options (if type is select)"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the field is mandatory"
        },
        "order": {
          "type": "number",
          "description": "Display order in the form"
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the field is currently enabled"
        }
      },
      "required": ["key", "label", "type", "order", "isActive"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "A single entry in the ledger",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user/staff who created the entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "data": {
          "type": "object",
          "description": "Dynamic field data"
        }
      },
      "required": ["userId", "createdAt", "data"]
    }
  },
  "firestore": {
    "/ledger_config/{fieldId}": {
      "schema": "LedgerFieldConfig",
      "description": "Collection of dynamic field configurations"
    },
    "/ledger/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Collection of submitted ledger entries"
    }
  }
}
