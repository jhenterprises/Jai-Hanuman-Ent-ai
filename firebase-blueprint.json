{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and staff member details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "user"] },
        "staff_id": { "type": "string" },
        "designation": { "type": "string" },
        "address": { "type": "string" },
        "blood_group": { "type": "string" },
        "joining_date": { "type": "string" },
        "photo_url": { "type": "string" },
        "is_deleted": { "type": "boolean" },
        "salary_amount": { "type": "number" }
      }
    },
    "IDCardSettings": {
      "title": "ID Card Settings",
      "description": "Customization settings for the PVC ID card template",
      "type": "object",
      "properties": {
        "front_bg_color": { "type": "string" },
        "front_bg_image": { "type": "string" },
        "back_bg_color": { "type": "string" },
        "back_bg_image": { "type": "string" },
        "company_logo": { "type": "string" },
        "company_name": { "type": "string" },
        "company_tagline": { "type": "string" },
        "text_color": { "type": "string" },
        "accent_color": { "type": "string" },
        "border_color": { "type": "string" },
        "header_bg_color": { "type": "string" },
        "footer_bg_color": { "type": "string" },
        "instructions": { "type": "string" },
        "emergency_contact": { "type": "string" },
        "website": { "type": "string" },
        "signature_url": { "type": "string" },
        "card_width": { "type": "number" },
        "card_height": { "type": "number" },
        "enabled_fields": { "type": "array" },
        "font_size_name": { "type": "number" },
        "font_size_details": { "type": "number" }
      }
    },
    "LedgerFieldConfig": {
      "title": "Ledger Field Configuration",
      "description": "Configuration for dynamic ledger input fields",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Unique key for the field (camelCase, no spaces)"
        },
        "label": {
          "type": "string",
          "description": "Display label for the field"
        },
        "type": {
          "type": "string",
          "enum": ["text", "number", "select", "date"],
          "description": "Input type"
        },
        "options": {
          "type": "array",
          "description": "Dropdown options (if type is select)"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the field is mandatory"
        },
        "order": {
          "type": "number",
          "description": "Display order in the form"
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the field is currently enabled"
        }
      },
      "required": ["key", "label", "type", "order", "isActive"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "A single entry in the ledger",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user/staff who created the entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "data": {
          "type": "object",
          "description": "Dynamic field data"
        }
      },
      "required": ["userId", "createdAt", "data"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User wallet balance information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "frozen"] },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "FinancialTransaction": {
      "title": "Financial Transaction",
      "description": "Records for recharges, bill payments, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["recharge", "bill_pay", "dmt", "aeps", "wallet_load"] },
        "amount": { "type": "number" },
        "commission": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "success", "failed", "processing"] },
        "txId": { "type": "string" },
        "refNo": { "type": "string" },
        "operator": { "type": "string" },
        "number": { "type": "string" },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ServiceConfig": {
      "title": "Service Configuration",
      "description": "Admin settings for different services and commissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isActive": { "type": "boolean" },
        "commission_type": { "type": "string", "enum": ["flat", "percentage"] },
        "commission_value": { "type": "number" },
        "provider": { "type": "string" }
      }
    },
    "ServiceControl": {
      "title": "Service Control",
      "description": "Availability control for financial services",
      "type": "object",
      "properties": {
        "serviceKey": { "type": "string" },
        "serviceName": { "type": "string" },
        "isLive": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "comingSoon": { "type": "boolean" },
        "bannerMessage": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" },
        "apiStatus": { "type": "string", "enum": ["connected", "disconnected", "maintenance"] },
        "lastChecked": { "type": "string", "format": "date-time" },
        "provider": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceKey", "serviceName", "isLive", "updatedAt"]
    },
    "WalletLog": {
      "title": "Wallet Log",
      "description": "Ledger of all wallet balance changes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "previousBalance": { "type": "number" },
        "newBalance": { "type": "number" },
        "reason": { "type": "string" },
        "txId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User wallet balances"
    },
    "/financial_transactions/{txId}": {
      "schema": "FinancialTransaction",
      "description": "Consolidated financial transactions"
    },
    "/wallet_logs/{logId}": {
      "schema": "WalletLog",
      "description": "Audit trail for wallet changes"
    },
    "/services_config/{serviceId}": {
      "schema": "ServiceConfig",
      "description": "Admin settings for various services"
    },
    "/service_controls/{serviceId}": {
      "schema": "ServiceControl",
      "description": "Live control and status for financial services"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and staff data"
    },
    "/id_card_settings/default": {
      "schema": "IDCardSettings",
      "description": "Global ID card template settings"
    },
    "/ledger_config/{fieldId}": {
      "schema": "LedgerFieldConfig",
      "description": "Collection of dynamic field configurations"
    },
    "/ledger/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Collection of submitted ledger entries"
    }
  }
}
